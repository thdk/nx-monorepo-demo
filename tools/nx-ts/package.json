{
  "name": "@thdk/nx-ts",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "outputPath": "tools/nx-ts/dist",
          "main": "tools/nx-ts/src/index.ts",
          "rootDir": "{projectRoot}/src",
          "tsConfig": "tools/nx-ts/tsconfig.lib.json",
          "generatePackageJson": false,
          "assets": [
            {
              "input": "./tools/nx-ts/src",
              "glob": "**/!(*.ts)",
              "output": "."
            },
            {
              "input": "./tools/nx-ts/src",
              "glob": "**/*.d.ts",
              "output": "."
            }
          ]
        }
      }
    }
  },
  "dependencies": {
    "tslib": "2.8.1"
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo",
    "generators.json"
  ],
  "generators": "./generators.json"
}
