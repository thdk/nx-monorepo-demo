{
  "name": "@thdk/source",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "nx": {
    "targets": {
      "all": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "nx format",
            "nx syncpack-fix",
            "nx affected --target lint -- --fix",
            "nx affected --target build test typecheck terraform-format"
          ],
          "parallel": false
        }
      },
      "run-affected": {
        "executor": "nx:run-commands",
        "options": {
          "command": "nx affected --target build lint test syncpack"
        }
      },
      "release-custom": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsx ./scripts/bin/release.ts"
        }
      },
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      },
      "syncpack": {
        "command": "pnpm exec syncpack lint"
      },
      "syncpack-fix": {
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "pnpm exec syncpack fix-mismatches",
            "pnpm exec syncpack format",
            "pnpm install"
          ],
          "parallel": false
        }
      }
    }
  },
  "dependencies": {
    "@fastify/autoload": "6.0.3",
    "@fastify/sensible": "6.0.2",
    "@nestjs/common": "11.0.0",
    "@nestjs/core": "11.0.0",
    "@nestjs/platform-express": "11.0.0",
    "@react-router/node": "7.14.2",
    "@react-router/serve": "7.14.2",
    "fastify": "5.2.1",
    "fastify-plugin": "5.0.1",
    "isbot": "4.4.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router": "7.14.2",
    "react-router-dom": "7.14.2",
    "reflect-metadata": "0.1.13",
    "rxjs": "7.8.0"
  },
  "devDependencies": {
    "@eslint/js": "9.8.0",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.0",
    "@nx/devkit": "22.7.5",
    "@nx/docker": "22.7.5",
    "@nx/esbuild": "22.7.5",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/jest": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/nest": "22.7.5",
    "@nx/node": "22.7.5",
    "@nx/playwright": "22.7.5",
    "@nx/plugin": "22.7.5",
    "@nx/react": "22.7.5",
    "@nx/vite": "22.7.5",
    "@nx/vitest": "22.7.5",
    "@nx/web": "22.7.5",
    "@nx/webpack": "22.7.5",
    "@nx/workspace": "22.7.5",
    "@playwright/test": "1.52.0",
    "@react-router/dev": "7.14.2",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.7.10",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.21",
    "@swc/jest": "0.2.39",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@thdk/nest-lib-a": "workspace:*",
    "@thdk/skill-eval": "workspace:*",
    "@types/jest": "30.0.0",
    "@types/node": "22.15.21",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/yargs": "17.0.33",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "@vitejs/plugin-react": "5.1.0",
    "@vitest/coverage-v8": "4.0.9",
    "@vitest/ui": "4.0.9",
    "esbuild": "0.28.0",
