{
  "name": "node-nest-webpack",
  "tags": ["deployable:docker", "scope:nx-demo"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "prune-lockfile": {
      "options": {
        "buildTarget": "build",
        "outputPath": "{projectRoot}/dist"
      }
    },
    "copy-workspace-modules": {},
    "prune": {
      "executor": "nx:run-commands",
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "outputs": ["{projectRoot}/dist/pnpm-workspace.yaml"],
      "options": {
        "command": "tsx ./scripts/bin/write-dist-pnpm-workspace.ts {projectRoot}/dist"
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "node-nest-webpack:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "node-nest-webpack:build:development"
        },
        "production": {
          "buildTarget": "node-nest-webpack:build:production"
        }
      }
    }
  }
}
