{
  "name": "@thdk/node-tsc",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "node-tsc",
    "targets": {
      "serve": {
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "node-tsc:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "node-tsc:build:development"
          },
          "production": {
            "buildTarget": "node-tsc:build:production"
          }
        }
      }
    }
  },
  "dependencies": {
    "@thdk/lib-b": "workspace:*",
    "tslib": "2.8.1"
  }
}
