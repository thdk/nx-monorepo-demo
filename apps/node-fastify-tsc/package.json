{
  "name": "@thdk/node-fastify-tsc",
  "version": "0.4.0",
  "private": true,
  "nx": {
    "name": "node-fastify-tsc",
    "tags": [
      "deployable:docker"
    ],
    "targets": {
      "serve": {
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "node-fastify-tsc:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "node-fastify-tsc:build:development"
          },
          "production": {
            "buildTarget": "node-fastify-tsc:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      },
      "prune-lockfile": {},
      "copy-workspace-modules": {},
      "prune": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "outputs": [
          "{projectRoot}/dist/pnpm-workspace.yaml"
        ],
        "options": {
          "command": "tsx ./scripts/bin/write-dist-pnpm-workspace.ts {projectRoot}/dist"
        }
      }
    }
  },
  "dependencies": {
    "@fastify/sensible": "6.0.2",
    "@thdk/lib-a": "workspace:*",
    "@thdk/lib-b": "workspace:*",
    "@thdk/lib-c": "workspace:*",
    "fastify": "5.2.1",
    "fastify-plugin": "5.0.1",
    "tslib": "2.8.1"
  }
}
