{
  "name": "@thdk/react-components-css-vite",
  "version": "0.0.5",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.mjs"
    },
    "./*/styles.css": "./dist/*/styles.css"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "vite-plugin-lib-inject-css": "^2.2.2",
    "react": "19.0.0"
  }
}
